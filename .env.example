# Copy this file to `.env` and fill in your GCN Kafka credentials.
# Generate them at https://gcn.nasa.gov/quickstart (one client_id/secret per app).
#
# The gcn-listener binary loads these via dotenvy on startup.

GCN_CLIENT_ID=your-client-id-here
GCN_CLIENT_SECRET=your-client-secret-here

# Optional: override defaults
# GCN_GROUP_ID=boom-moc-index
# GCN_DOMAIN=gcn.nasa.gov
# REDIS_URL=redis://127.0.0.1:6390
# CREDIBLE_LEVEL=0.95
# VALIDITY_SECONDS=1209600  # 14 days
